# Local dev — override these in .env (never commit .env)

# ── Database ──────────────────────────────────────────────────────────────────
# docker-compose.prod.yml injects POSTGRES_* into the postgres container
POSTGRES_USER=atbatwatch
POSTGRES_PASSWORD=changeme
POSTGRES_DB=atbatwatch

# SQLAlchemy URL used by the app services
# In prod the hostname is "postgres" (the compose service name)
DATABASE_URL=postgresql+asyncpg://atbatwatch:changeme@postgres:5432/atbatwatch

# For local dev (services running outside Docker):
# DATABASE_URL=postgresql+asyncpg://atbatwatch:atbatwatch@localhost:5432/atbatwatch

# ── Redis ─────────────────────────────────────────────────────────────────────
# In prod the hostname is "redis" (the compose service name)
REDIS_URL=redis://redis:6379/0

# For local dev:
# REDIS_URL=redis://localhost:6379/0

# ── Poller ───────────────────────────────────────────────────────────────────
# How often to poll MLB API for live game updates (seconds)
POLL_INTERVAL_SECONDS=10

# ── Caddy (optional — set once you have a domain) ────────────────────────────
# DOMAIN=atbatwatch.example.com

# ── Hetzner Storage Box (optional — for nightly backups) ────────────────────
# STORAGE_BOX_HOST=u123456.your-storagebox.de
# STORAGE_BOX_USER=u123456
